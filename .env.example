# ============================================================
# BASE DE DONNÉES — Railway fournit cette URL automatiquement
# NE PAS TOUCHER si vous déployez sur Railway (Railway la remplit)
# En local : postgresql://user:password@localhost:5432/assurpilot
# ============================================================
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# ============================================================
# NEXTAUTH — Authentification
# ============================================================
# URL de votre app Railway (ex: https://assurpilot-production.up.railway.app)
NEXTAUTH_URL="https://VOTRE-APP.up.railway.app"

# Clé secrète — générez-en une sur : https://generate-secret.vercel.app/32
NEXTAUTH_SECRET="changez-moi-avec-une-longue-chaine-aleatoire"

# ============================================================
# URL PUBLIQUE DE L'APP (pour les webhooks Vapi)
# Même valeur que NEXTAUTH_URL
# ============================================================
NEXT_PUBLIC_APP_URL="https://VOTRE-APP.up.railway.app"

# ============================================================
# VAPI — https://dashboard.vapi.ai
# ============================================================
# Votre clé API Vapi (dashboard.vapi.ai → Account → API Keys)
VAPI_API_KEY="COLLER_VOTRE_CLE_VAPI_ICI"

# ID de votre numéro de téléphone Vapi
# dashboard.vapi.ai → Phone Numbers → cliquer sur le numéro → Phone Number ID
VAPI_PHONE_NUMBER_ID="COLLER_VOTRE_PHONE_NUMBER_ID_ICI"

# ============================================================
# ANTHROPIC — https://console.anthropic.com → API Keys
# Requis pour claude-haiku-4-5 ou claude-sonnet-4-6
# ============================================================
ANTHROPIC_API_KEY="COLLER_VOTRE_CLE_ANTHROPIC_ICI"

# ============================================================
# GOOGLE — https://aistudio.google.com → Get API Key
# Requis si vous utilisez gemini-flash
# ============================================================
GOOGLE_API_KEY="COLLER_VOTRE_CLE_GOOGLE_ICI"
